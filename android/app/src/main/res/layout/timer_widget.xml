<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="16dp">

        <ImageView
            android:id="@+id/widget_progress_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Timer Progress"
            android:scaleType="fitCenter" />
            
        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher"
            android:alpha="0.8" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BlinkKind"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20:00"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:layout_marginTop="-2dp"
            android:layout_marginBottom="-2dp" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Work Phase"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false" />

        <LinearLayout
            android:id="@+id/widget_button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_btn_postpone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Postpone"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/widget_button_bg"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/widget_btn_skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/widget_button_bg"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
