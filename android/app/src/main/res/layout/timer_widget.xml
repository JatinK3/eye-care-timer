<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center">

    <!-- Progress Ring container containing time and status -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal">

        <ImageView
            android:id="@+id/widget_progress_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Timer Progress"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <TextView
                android:id="@+id/widget_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20:00"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Work"
                android:textColor="#4CAF50"
                android:textSize="10sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BlinkKind"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginTop="8dp"
        android:layout_gravity="center_horizontal" />

    <LinearLayout
        android:id="@+id/widget_button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_btn_postpone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Postpone"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:background="@drawable/widget_button_bg"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/widget_btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:background="@drawable/widget_button_bg"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
